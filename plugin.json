{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-overlay-draw",
  "name": {
    "en": "Pin Doodle",
    "ko": "Pin \ub099\uc11c"
  },
  "version": "0.0.1",
  "description": {
    "en": "Freehand drawing overlay on top of the screen. In draw mode use the pen to doodle; outside draw mode clicks pass through but the drawing stays visible and appears in screenshots. Color, width, eraser, undo, clear.",
    "ko": "\ud654\uba74 \uc704\uc5d0 \uc5f0\ud544\ub85c \uc790\uc720\ub86d\uac8c \uc801\uace0 \uadf8\ub9ac\ub294 \ub099\uc11c \uc624\ubc84\ub808\uc774. \uadf8\ub9ac\uae30 \ubaa8\ub4dc\ub97c \ucf1c\uba74 \ud39c\uc73c\ub85c \ub099\uc11c\ud558\uace0, \ub044\uba74 \ud074\ub9ad\uc740 \ud1b5\uacfc\ud558\ub418 \ub099\uc11c\ub294 \ud654\uba74\uc5d0 \ub0a8\uc544 \uc2a4\ud06c\ub9b0\uc0f7\uc5d0\ub3c4 \uc7a1\ud78c\ub2e4. \uc0c9\u00b7\uad75\uae30\u00b7\uc9c0\uc6b0\uac1c\u00b7\ub418\ub3cc\ub9ac\uae30\u00b7\uc9c0\uc6b0\uae30."
  },
  "entry": "main.js",
  "permissions": [
    "ui:overlay:screen",
    "ui:titlebar",
    "commands"
  ],
  "contributes": {
    "commands": [
      {
        "name": "toggle",
        "title": {
          "en": "Toggle draw mode",
          "ko": "\uadf8\ub9ac\uae30 \ubaa8\ub4dc \ucf1c\uae30/\ub044\uae30"
        }
      },
      {
        "name": "color",
        "title": {
          "en": "Pen color",
          "ko": "\ud39c \uc0c9"
        }
      },
      {
        "name": "width",
        "title": {
          "en": "Pen width",
          "ko": "\ud39c \uad75\uae30"
        }
      },
      {
        "name": "eraser",
        "title": {
          "en": "Eraser",
          "ko": "\uc9c0\uc6b0\uac1c"
        }
      },
      {
        "name": "stroke",
        "title": {
          "en": "Draw stroke (programmatic)",
          "ko": "\ub099\uc11c \ud55c \ud68d(\ud504\ub85c\uadf8\ub7a8\u00b7AI\u00b7E2E)"
        }
      },
      {
        "name": "tools",
        "title": {
          "en": "Hide/show tools (for capture)",
          "ko": "\ub3c4\uad6c \uac00\ub9ac\uae30/\uc5f4\uae30(\ucea1\ucc98\uc6a9)"
        }
      },
      {
        "name": "undo",
        "title": {
          "en": "Undo",
          "ko": "\ub418\ub3cc\ub9ac\uae30"
        }
      },
      {
        "name": "clear",
        "title": {
          "en": "Clear all",
          "ko": "\uc804\ubd80 \uc9c0\uc6b0\uae30"
        }
      },
      {
        "name": "state",
        "title": {
          "en": "Read state",
          "ko": "\uc0c1\ud0dc \uc77d\uae30"
        }
      }
    ]
  }
}
